# Environment variables for GitHub AI Contributions

# GCP Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# Airflow Configuration
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-generate-with-airflow-connections-create

# Optional: Email alerts
AIRFLOW__EMAIL__SMTP_HOST=smtp.gmail.com
AIRFLOW__EMAIL__SMTP_USER=your-email@gmail.com
AIRFLOW__EMAIL__SMTP_PASSWORD=your-app-password
